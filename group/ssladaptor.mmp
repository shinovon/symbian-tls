//ssladaptor.dll for 7.0-8.0
TARGET ssladaptor.dll
TARGETTYPE dll
UID 0x101f35f0 0x101f35ee

SOURCEPATH ../src
SOURCE ssladaptor.cpp

USERINCLUDE ../inc

#ifdef EKA2
SYSTEMINCLUDE /epoc32/include
SYSTEMINCLUDE /epoc32/include/libc
SYSTEMINCLUDE /epoc32/include/platform
#else
SYSTEMINCLUDE \epoc32\include
SYSTEMINCLUDE \epoc32\include\libc
#endif

LIBRARY	euser.lib
LIBRARY ssl.lib

DEFFILE ssladaptor.def

