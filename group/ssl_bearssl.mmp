#ifdef EKA2
TARGET ssl_bearssl.dll
#else
TARGET ssl_81.dll
#endif
DEFFILE ssl.def

#include "newtls.mmh"

LIBRARY estlib.lib

#ifdef EKA2
NOEXPORTLIBRARY
SYSTEMINCLUDE /epoc32/include/bearssl
SYSTEMINCLUDE /epoc32/include/libc
#else
SYSTEMINCLUDE \epoc32\include
SYSTEMINCLUDE \epoc32\include\libc
SYSTEMINCLUDE ..\..\bearssl\inc
#endif
STATICLIBRARY bearssl.lib

MACRO BEARSSL
MACRO NO_VERIFY
